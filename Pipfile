[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
# Pinned to the major version. StripeObject stopped deriving from dict, which silently removed
# .get() from every object the SDK returns -- the kind of break an unpinned "*" lets into a
# container build without anyone touching the code.
stripe = "~=15.3"
boto3 = "*"
psycopg2-binary = "*"
requests = "*"
pytest = "*"
ratelimit = "*"
Xlsxwriter = "*"
smartystreets_python_sdk = "*"

[dev-packages]

[requires]
python_version = "3.13"
